# Database (SQL Server / Azure SQL)
DB_SERVER=your-sql-server.database.windows.net
DB_NAME=travelbuddy
DB_USER=travelbuddy_admin
DB_PASSWORD=your-password

# Auth
JWT_SECRET=your-256-bit-random-string

# Optional: refresh token secret used for rotating refresh tokens
JWT_REFRESH_SECRET=your-refresh-secret

# Node environment
NODE_ENV=development

# Google Maps (browser-restricted key for frontend, server-restricted for backend)
GOOGLE_MAPS_KEY=your-maps-key

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Redis (Upstash)
REDIS_URL=redis://default:password@your-upstash-endpoint:port

# App
FRONTEND_URL=http://localhost:5173
PORT=5000

# Email (SMTP) - Gmail App Password or other SMTP credentials
EMAIL_USER=your-email@example.com
EMAIL_APP_PASSWORD=your-email-app-password

# External API keys
OPENROUTER_KEY=your-openrouter-key-or-other-ai-key
GOOGLE_PLACES_API_KEY=your-google-places-key
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Photo API keys (Unsplash / Pexels)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
